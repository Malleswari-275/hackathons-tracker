{
  "info": {
    "name": "Hackathon Management Portal API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"superadmin@portal.com\",\n  \"password\": \"superadmin123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"superadmin123\",\n  \"newPassword\": \"adminSecure2026\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/change-password",
              "host": ["{{base_url}}"],
              "path": ["auth", "change-password"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "User Management",
      "item": [
        {
          "name": "Create Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin1@university.edu\",\n  \"employeeId\": \"EMP-CS-2026\",\n  \"name\": \"Professor Jane CS\",\n  \"designation\": \"Professor\",\n  \"department\": \"Computer Science\",\n  \"organization\": \"Tech University\",\n  \"phone\": \"+155512345\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/admins",
              "host": ["{{base_url}}"],
              "path": ["users", "admins"]
            }
          }
        },
        {
          "name": "Create Student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alex@student.edu\",\n  \"rollNumber\": \"CS-ROLL-045\",\n  \"name\": \"Alex Riviera\",\n  \"year\": 3,\n  \"department\": \"Computer Science\",\n  \"section\": \"A\",\n  \"cgpa\": 9.1,\n  \"skills\": [\"JavaScript\", \"Node.js\"],\n  \"phone\": \"+15550212\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/students",
              "host": ["{{base_url}}"],
              "path": ["users", "students"]
            }
          }
        },
        {
          "name": "List Admins",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/users/admins",
              "host": ["{{base_url}}"],
              "path": ["users", "admins"]
            }
          }
        },
        {
          "name": "List Students",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/users/students",
              "host": ["{{base_url}}"],
              "path": ["users", "students"]
            }
          }
        }
      ]
    },
    {
      "name": "Competitions",
      "item": [
        {
          "name": "Create Competition",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"National Innovation Hackathon 2026\",\n  \"organization\": \"Tech Labs Inc\",\n  \"eventType\": \"HACKATHON\",\n  \"description\": \"Solve state of the art web issues.\",\n  \"registrationUrl\": \"https://hackathon.techlabs.com\",\n  \"mode\": \"HYBRID\",\n  \"location\": {\n    \"city\": \"Chicago\",\n    \"state\": \"Illinois\",\n    \"country\": \"USA\"\n  },\n  \"eligibility\": {\n    \"departments\": [\"Computer Science\"],\n    \"years\": [3, 4]\n  },\n  \"timeline\": {\n    \"registrationStart\": \"2026-06-01T00:00:00.000Z\",\n    \"registrationDeadline\": \"2026-06-25T23:59:59.000Z\",\n    \"startDate\": \"2026-07-01T08:00:00.000Z\",\n    \"endDate\": \"2026-07-03T18:00:00.000Z\"\n  },\n  \"rounds\": [\n    {\n      \"title\": \"Proposal Pitch\",\n      \"description\": \"PDF submission.\",\n      \"status\": \"UPCOMING\"\n    }\n  ],\n  \"prizes\": [\n    {\n      \"title\": \"Grand Prize\",\n      \"amount\": 5000\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/competitions",
              "host": ["{{base_url}}"],
              "path": ["competitions"]
            }
          }
        },
        {
          "name": "Get Competitions List",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/competitions?limit=10&page=1&status=PENDING",
              "host": ["{{base_url}}"],
              "path": ["competitions"],
              "query": [
                { "key": "limit", "value": "10" },
                { "key": "page", "value": "1" },
                { "key": "status", "value": "PENDING" }
              ]
            }
          }
        },
        {
          "name": "Approve Competition",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/competitions/{{competition_id}}/approve",
              "host": ["{{base_url}}"],
              "path": ["competitions", "{{competition_id}}", "approve"]
            }
          }
        }
      ]
    },
    {
      "name": "Assignments",
      "item": [
        {
          "name": "Assign Mentor & Students",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"competitionId\": \"{{competition_id}}\",\n  \"assignedMentors\": [\"{{mentor_user_id}}\"],\n  \"assignedStudents\": [\"{{student_user_id}}\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/assignments",
              "host": ["{{base_url}}"],
              "path": ["assignments"]
            }
          }
        },
        {
          "name": "Get Assignments",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/assignments/{{competition_id}}",
              "host": ["{{base_url}}"],
              "path": ["assignments", "{{competition_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Registrations",
      "item": [
        {
          "name": "Student Update Response",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"REGISTERED\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/registrations/{{competition_id}}",
              "host": ["{{base_url}}"],
              "path": ["registrations", "{{competition_id}}"]
            }
          }
        },
